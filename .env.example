# ============================================================
#  JAIN DEVELOPERS LMS — .env (optional)
#
#  Firebase credentials are loaded from:
#    config/serviceAccountKey.json
#  (already bundled — no Firebase env vars needed!)
#
#  Only add these if you use GitHub video storage:
# ============================================================

PORT=5000
NODE_ENV=development

# JWT secret for admin panel login (any long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# GitHub video repo (only needed for video upload/sync features)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=lms-videos
GITHUB_BRANCH=main
